<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="OTP Yönlendirici"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="24dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Hedef Telefon Numarası"
        android:textSize="16sp"/>

    <EditText
        android:id="@+id/etTargetPhone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="4-8 haneli numara"
        android:inputType="number"
        android:maxLength="8"
        android:layout_marginTop="8dp"/>

    <Button
        android:id="@+id/btnSave"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Kaydet"
        android:layout_marginTop="16dp"/>

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Hedef numara belirtilmemiş"
        android:textSize="14sp"
        android:layout_marginTop="24dp"
        android:padding="8dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Bu uygulama, gelen SMS'lerden doğrulama kodlarını (4-8 haneli) tespit eder ve tam mesajı belirtilen hedef numaraya iletir."
        android:textSize="12sp"
        android:layout_marginTop="16dp"
        android:textColor="#666666"/>

</LinearLayout>